# Copy to .env and fill in (never commit .env).
SPLUNK_O11Y_ACCESS_TOKEN=
SPLUNK_OPENSHIFT_CLUSTER_NAME=
# Optional Splunk Observability realm (default us1).
SPLUNK_O11Y_REALM=us1
# Namespace must be a valid DNS label (lowercase). Matches OpenShift project "otel".
INSTALL_NAMESPACE=otel
# Optional overrides for OBI prerequisites (defaults shown).
# OBI_SERVICE_ACCOUNT=splunk-otel-collector-obi
# OBI_SCC_NAME=splunk-otel-obi-scc
# HELM_TIMEOUT=5m
# HELM_TIMEOUT_OBI=8m
