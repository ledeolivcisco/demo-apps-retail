# Copy to docker/.env (same directory as docker-compose.yml):
#   cp docker/.env.example docker/.env
#
# Compose auto-loads docker/.env. The web Dockerfile copies this file as
# .env.production so VITE_* keys are baked into the static bundle at build time.

# --- Image naming (local build or registry push) ---
REGISTRY_PREFIX=leandrovo
# Tag all app images on push. Scenario-specific tags (see docker/scripts/build-push-scenario.sh):
#   appd   — AppDynamics Docker Compose / docker-standalone (VITE_OBSERVABILITY_BACKEND=appdynamics)
#   splunk — Kubernetes + o11y/ Splunk stack (VITE_OBSERVABILITY_BACKEND=splunk)
# JVM backends are identical for both; only ecommerce-web differs (RUM baked at build time).
IMAGE_TAG=latest

# --- Host ports ---
WEB_PORT=8080
PRODUCT_PORT=8081
CART_PORT=8082
PAYMENT_PORT=8083

# --- SQL Server (shared application database) ---
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
MSSQL_PORT=1433
# WALLMART_DB_HOST=sqlserver
# WALLMART_DB_PORT=1433
# WALLMART_DB_NAME=wallmart
# WALLMART_DB_USER=sa
# WALLMART_DB_PASSWORD=${MSSQL_SA_PASSWORD}
# WALLMART_DB_BOOTSTRAP=true

# --- Demo / chaos scenarios (product-service only; default off) ---
# WALLMART_DEMO_CHAOS_ENABLED=false
# When true, product-service exposes internal demo endpoints (no session headers required):
#   POST http://localhost:8081/internal/demo/db-lock/inventory?seconds=60
#   POST http://localhost:8081/internal/demo/db-config/blocked-process-threshold?seconds=10
#   POST http://localhost:8081/internal/demo/db-config/blocked-process-threshold/restore

# --- AppDynamics Java APM (required for JVM services) ---
APPDYNAMICS_APPLICATION_NAME=wallmart-ecommerce
APPDYNAMICS_CONTROLLER_HOST_NAME=
APPDYNAMICS_AGENT_ACCOUNT_NAME=
APPDYNAMICS_AGENT_ACCOUNT_ACCESS_KEY=
# APPDYNAMICS_CONTROLLER_PORT=443
# APPDYNAMICS_CONTROLLER_SSL_ENABLED=true
# APPDYNAMICS_AGENT_TIER_NAME_PRODUCT=product-service
# APPDYNAMICS_AGENT_NODE_NAME_PRODUCT=product-1
# APPDYNAMICS_AGENT_TIER_NAME_CART=cart-service
# APPDYNAMICS_AGENT_NODE_NAME_CART=cart-1
# APPDYNAMICS_AGENT_TIER_NAME_PAYMENT=payment-service
# APPDYNAMICS_AGENT_NODE_NAME_PAYMENT=payment-1

# --- AppDynamics DB Visibility (db-agent service) ---
# Agent name SQLDBSales and hostname sqldbsales are fixed in docker-compose.yml (not overridable).
# After stack is up, create an MSSQL collector in the Controller UI:
#   host sqlserver, port 1433, user sa, password MSSQL_SA_PASSWORD above.
# APPDYNAMICS_DB_PROPERTIES=-Ddbagent.telemetry.enabled=true

# --- AppDynamics machine-agent (infra / SIM / Docker) ---
# hostname and APPDYNAMICS_AGENT_UNIQUE_HOST_ID are fixed in compose as wallmart-docker-host.
# APPDYNAMICS_SIM_ENABLED=true
# APPDYNAMICS_DOCKER_ENABLED=true

# --- Inter-service URLs (cart-service; defaults work inside compose network) ---
# WALLMART_PRODUCT_SERVICE_BASE_URL=http://product-service:8081
# WALLMART_PAYMENT_SERVICE_BASE_URL=http://payment-service:8083

# --- Browser RUM (Vite production build — see ecommerce-web/.env.example) ---
# Do NOT commit real keys.
# Master switch: appdynamics | splunk | none
VITE_OBSERVABILITY_BACKEND=appdynamics
VITE_APPDYNAMICS_ENABLED=false
# VITE_APPDYNAMICS_APP_KEY=
# VITE_APPDYNAMICS_ADRUM_EXT_URL_HTTPS=https://cdn.appdynamics.com
# VITE_APPDYNAMICS_ADRUM_EXT_URL_HTTP=http://cdn.appdynamics.com
# VITE_APPDYNAMICS_BEACON_URL_HTTPS=https://col.eum-appdynamics.com
# VITE_APPDYNAMICS_BEACON_URL_HTTP=http://col.eum-appdynamics.com
# VITE_APPDYNAMICS_SPA2=true

# Splunk Browser RUM (K8s + o11y/ path — set backend=splunk and rebuild web image)
# VITE_OBSERVABILITY_BACKEND=splunk
# VITE_SPLUNK_REALM=us1
# VITE_SPLUNK_RUM_ACCESS_TOKEN=
# VITE_SPLUNK_APPLICATION_NAME=ecommerce-web
# VITE_SPLUNK_DEPLOYMENT_ENVIRONMENT=dev

# --- Synthetic E2E loop (profile: synthetic) ---
# PLAYWRIGHT_BASE_URL=http://ecommerce-web
# PLAYWRIGHT_LOOP_INTERVAL_SECONDS=30
# PLAYWRIGHT_WORKERS=4
# PLAYWRIGHT_FULLY_PARALLEL=true
# PLAYWRIGHT_SYNTHETIC_PACE_MS=500
