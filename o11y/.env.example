# Splunk Observability Cloud
SPLUNK_REALM=us1
SPLUNK_ACCESS_TOKEN=

# Splunk Platform HEC (logs)
SPLUNK_HEC_TOKEN=
SPLUNK_HEC_ENDPOINT=https://your-splunk-host:8088/services/collector
SPLUNK_HEC_INDEX=main

# Cluster identity (appears on all telemetry)
CLUSTER_NAME=wallmart-local
DEPLOYMENT_ENV=dev

# Kubernetes
COLLECTOR_NAMESPACE=splunk-otel
COLLECTOR_RELEASE=splunk-otel-collector
WALLMART_NAMESPACE=wallmart
