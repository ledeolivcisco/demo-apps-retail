# Copy to .env in this directory: cp .env.example .env
# Compose loads .env from this folder when the project uses run/docker-compose.yaml.

# Required (no defaults in compose)
APPDYNAMICS_CONTROLLER_HOST_NAME=
APPDYNAMICS_AGENT_ACCOUNT_NAME=
APPDYNAMICS_AGENT_ACCOUNT_ACCESS_KEY=

# Optional (defaults shown in docker-compose.yaml)
# APPDYNAMICS_AGENT_TIER_NAME=mygame-api
# APPDYNAMICS_AGENT_NODE_NAME=mygame-1
# APPDYNAMICS_CONTROLLER_PORT=443
# APPDYNAMICS_CONTROLLER_SSL_ENABLED=true
