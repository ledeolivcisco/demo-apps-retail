# Copy to .env.local and fill in values. Do NOT commit real keys.

# Optional: prefix for API calls in production (dev uses Vite proxy when unset).
# VITE_API_BASE_URL=

# --- Frontend RUM backend (pick one) ---
# appdynamics | splunk | none
# When unset, falls back to VITE_APPDYNAMICS_ENABLED=true → appdynamics.
VITE_OBSERVABILITY_BACKEND=none

# --- AppDynamics Browser RUM (when backend=appdynamics) ---
# User Experience > Browser RUM > your app > "Get your application key".
VITE_APPDYNAMICS_ENABLED=false
VITE_APPDYNAMICS_APP_KEY=

# Override if your Controller snippet shows different hosts (SaaS region / on-prem).
# VITE_APPDYNAMICS_ADRUM_EXT_URL_HTTPS=https://cdn.appdynamics.com
# VITE_APPDYNAMICS_ADRUM_EXT_URL_HTTP=http://cdn.appdynamics.com
# VITE_APPDYNAMICS_BEACON_URL_HTTPS=https://col.eum-appdynamics.com
# VITE_APPDYNAMICS_BEACON_URL_HTTP=http://col.eum-appdynamics.com
# VITE_APPDYNAMICS_AGENT_SCRIPT_URL=https://cdn.appdynamics.com/adrum/adrum-latest.js
# VITE_APPDYNAMICS_SPA2=true
# VITE_APPDYNAMICS_XD_ENABLE=false

# --- Splunk Browser RUM (when backend=splunk) ---
# RUM token: Observability Cloud → Settings → Access Tokens → RUM (not SPLUNK_ACCESS_TOKEN).
# VITE_SPLUNK_REALM=us1
# VITE_SPLUNK_RUM_ACCESS_TOKEN=
# VITE_SPLUNK_APPLICATION_NAME=ecommerce-web
# VITE_SPLUNK_DEPLOYMENT_ENVIRONMENT=dev
# VITE_SPLUNK_SPA_METRICS=true
