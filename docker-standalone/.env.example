# Copy to .env next to docker-compose.yml:
#   cp .env.example .env
#
# Registry — images must exist as ${REGISTRY_PREFIX}/${service}:${IMAGE_TAG}
# (see docker/scripts/push-all.sh in the repo for product/cart/payment/ecommerce-web).
# AppDynamics path: use IMAGE_TAG=appd (build with ./docker/scripts/build-push-scenario.sh appd).

REGISTRY_PREFIX=leandrovo
IMAGE_TAG=appd

# Optional: always pull from registry (default missing = use local if present)
# COMPOSE_PULL_POLICY=always

# Host ports
WEB_PORT=8080
PRODUCT_PORT=8081
CART_PORT=8082
PAYMENT_PORT=8083

# --- SQL Server (shared application database) ---
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
MSSQL_PORT=1433

# AppDynamics (required for JVM, db-agent, and machine-agent)
APPDYNAMICS_APPLICATION_NAME=wallmart-ecommerce
APPDYNAMICS_CONTROLLER_HOST_NAME=
APPDYNAMICS_AGENT_ACCOUNT_NAME=
APPDYNAMICS_AGENT_ACCOUNT_ACCESS_KEY=
# APPDYNAMICS_CONTROLLER_PORT=443
# APPDYNAMICS_CONTROLLER_SSL_ENABLED=true
# APPDYNAMICS_AGENT_TIER_NAME_PRODUCT=product-service
# APPDYNAMICS_AGENT_NODE_NAME_PRODUCT=product-1
# APPDYNAMICS_AGENT_TIER_NAME_CART=cart-service
# APPDYNAMICS_AGENT_NODE_NAME_CART=cart-1
# APPDYNAMICS_AGENT_TIER_NAME_PAYMENT=payment-service
# APPDYNAMICS_AGENT_NODE_NAME_PAYMENT=payment-1

# --- AppDynamics DB Visibility (db-agent service) ---
# Agent name SQLDBSales and hostname sqldbsales are fixed in docker-compose.yml (not overridable).
# After stack is up, create an MSSQL collector in the Controller UI:
#   host sqlserver, port 1433, user sa, password MSSQL_SA_PASSWORD above.
# APPDYNAMICS_DB_PROPERTIES=-Ddbagent.telemetry.enabled=true

# --- AppDynamics machine-agent (infra / SIM / Docker) ---
# hostname and APPDYNAMICS_AGENT_UNIQUE_HOST_ID are fixed in compose as wallmart-docker-host.
# APPDYNAMICS_SIM_ENABLED=true
# APPDYNAMICS_DOCKER_ENABLED=true

# --- Demo / chaos scenarios (product-service only; default off) ---
# --- Demo / chaos scenarios (product-service only; default off) ---
# WALLMART_DEMO_CHAOS_ENABLED=false
# When true, product-service exposes internal demo endpoints (no session headers required):
#   POST http://localhost:8081/internal/demo/db-lock/inventory?seconds=60
#   POST http://localhost:8081/internal/demo/db-config/blocked-process-threshold?seconds=10
#   POST http://localhost:8081/internal/demo/db-config/blocked-process-threshold/restore

# Profile synthetic only — headless E2E loop (image must be built and pushed as playwright-loop)
# PLAYWRIGHT_BASE_URL=http://ecommerce-web
# PLAYWRIGHT_LOOP_INTERVAL_SECONDS=30
# PLAYWRIGHT_WORKERS=4
# PLAYWRIGHT_FULLY_PARALLEL=true
# PLAYWRIGHT_SYNTHETIC_PACE_MS=500
